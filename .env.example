# ============================================
# 智能阅读系统 环境变量配置
# 复制此文件为 .env 并填入你的实际值
# cp .env.example .env
# ============================================

# --- 数据库 ---
MYSQL_PASSWORD=your_mysql_password

# --- 认证 ---
APP_AUTH_TOKEN_SECRET=change_this_to_a_long_random_secret
APP_AUTH_TOKEN_TTL_MILLIS=86400000

# --- Dify 基础 URL（starter 自动配置 Bean 使用，不含 /chat-messages）---
DIFY_BASE_URL=https://api.dify.ai/v1

# --- Dify Chat 应用基础 URL（阅读助手/推荐/向导）---
DIFY_CHAT_URL=https://api.dify.ai/v1

# --- Dify Workflow 应用基础 URL（笔记 AI/洞察）---
DIFY_WORKFLOW_URL=https://api.dify.ai/v1

# --- Dify Chat Assistant 应用 ---
DIFY_READING_KEY=your_dify_reading_key      # 阅读助手：选中文本分析（解读/批判/联想）
DIFY_RECOMMEND_KEY=your_dify_recommend_key  # 书籍推荐：基于书架+协同过滤推荐
DIFY_GUIDE_KEY=your_dify_guide_key          # 系统向导：功能引导+阅读统计问答

# --- Dify Workflow 应用 ---
DIFY_NOTE_KEY=your_dify_note_key            # 笔记 AI：润色/摘要/测验
DIFY_INSIGHT_KEY=your_dify_insight_key      # 阅读洞察：生成个性化阅读报告

# --- Dify 知识库（Dataset API）---
DIFY_KB_URL=https://api.dify.ai/v1
DIFY_KB_KEY=dataset-xxxx                    # 知识库 API Key
DIFY_KB_DATASET_ID=your-dataset-uuid        # 知识库 Dataset ID
